{
  "name": "1stdibs Healthy Diet",
  "version": "1.2",
  "description": "Makes server switching easier",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://1stdibs.com/*",
    "*://*.1stdibs.com/*"
  ],
  "action": {
    "default_popup": "app/popup.html",
    "default_title": "1stdibs Healthy Diet"
  },
  "icons": {
    "16": "images/hd16.png",
    "32": "images/hd32.png",
    "48": "images/hd48.png",
    "128": "images/hd128.png"
  },
  "manifest_version": 3
}
